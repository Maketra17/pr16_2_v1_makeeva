<Window x:Class="_16_1_maakeeva.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_16_1_maakeeva"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="1103">

    <Grid Margin="10">
        <StackPanel Orientation="Vertical">
            <Label Content="Информация о студентах" Background="Coral" FontSize="20" HorizontalAlignment="Center" Height="40"/>

            <!-- Ввод данных....................................................................................... -->
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Фамилия:" Width="80" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSurname" Width="150" FontSize="14" Margin="0,0,20,0"/>
                    <Label Content="Группа:" Width="60" FontSize="14" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbGroup" Width="100" FontSize="14" Margin="0,0,20,0">
                        <ComboBoxItem Content="Пр-21"/>
                        <ComboBoxItem Content="Пр-22"/>
                        <ComboBoxItem Content="Пр-31"/>
                        <ComboBoxItem Content="Пр-32"/>
                    </ComboBox>
                    <Label Content="Специальность:" Width="100" FontSize="14" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbSpecialty" Width="150" FontSize="14">
                        <ComboBoxItem Content="Информатика"/>
                        <ComboBoxItem Content="Физика"/>
                        <ComboBoxItem Content="Математика"/>
                        <ComboBoxItem Content="Экономика"/>
                    </ComboBox>
                </StackPanel>
                <!-- Оценки....................................................................................... -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Label Content="Предмет 1:" Width="80" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSubject1" Width="120" FontSize="14" Text="птпм" Margin="0,0,10,0"/>
                    <Label Content="Оценка:" Width="60" FontSize="14" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbGrade1" Width="60" FontSize="14" Margin="0,0,20,0">
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5" IsSelected="True"/>
                    </ComboBox>
                    <Label Content="Предмет 2:" Width="80" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtSubject2" Width="120" FontSize="14" Text="рпм" Margin="0,0,10,0"/>
                    <Label Content="Оценка:" Width="60" FontSize="14" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbGrade2" Width="60" FontSize="14" Margin="0,0,20,0">
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5" IsSelected="True"/>
                    </ComboBox>
                    <Label Content="Предмет 3:" Width="83" FontSize="14"/>
                    <TextBox x:Name="txtSubject3" Width="95" FontSize="14" Text="уп"/>
                    <Label Content="Оценка:" Width="69" FontSize="14"/>
                    <ComboBox x:Name="cmbGrade3" Width="60" FontSize="14">
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5" IsSelected="True"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!-- Кнопка добавления....................................................................................... -->
            <Button x:Name="b1" Content="Добавить студента" FontSize="16" Foreground="White" Click="Add_Click" Width="200" Height="35" Background="Blue" Margin="0,10,0,10"/>

            <!-- Поиск....................................................................................... -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Поиск:" Width="60" FontSize="14" VerticalAlignment="Center"/>
                <TextBox x:Name="txtSearch" Width="150" FontSize="14" TextChanged="Search_TextChanged" Margin="0,0,10,0"/>
                <CheckBox x:Name="chkRegex" Content="Регулярные выражения" FontSize="14" VerticalAlignment="Center" Margin="0,0,20,0" Checked="Search_TextChanged" Unchecked="Search_TextChanged" Width="174"/>

                <Label Content="Фильтр по группе:" Width="120" FontSize="14" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbFilter" Width="100" FontSize="14" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все группы" IsSelected="True"/>
                    <ComboBoxItem Content="Пр-21"/>
                    <ComboBoxItem Content="Пр-22"/>
                    <ComboBoxItem Content="Пр-31"/>
                    <ComboBoxItem Content="Пр-32"/>
                </ComboBox>

                <Label Content="Сортировка:" Width="80" FontSize="14" VerticalAlignment="Center" Margin="20,0,0,0"/>
                <ComboBox x:Name="cmbSort" Width="120" FontSize="14" SelectionChanged="Sort_Changed">
                    <ComboBoxItem Content="По фамилии" IsSelected="True"/>
                    <ComboBoxItem Content="По группе"/>
                    <ComboBoxItem Content="По специальности"/>
                </ComboBox>
            </StackPanel>
            <DataGrid x:Name="dgStudents" AutoGenerateColumns="True" FontSize="14" Height="180" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Удалить выбранного" FontSize="16" Foreground="White" Width="160" Height="35" Click="Delete_Selected" Background="Red" Margin="0,0,20,0"/>
                <Button Content="Очистить список" FontSize="16" Foreground="White" Width="160" Height="35" Click="Clear_List" Background="Gray"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>